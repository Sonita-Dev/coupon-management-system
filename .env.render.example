APP_NAME="Coupon Management System"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-service-name.onrender.com
APP_KEY=base64:replace_with_php_artisan_key_generate_show

LOG_CHANNEL=stderr
LOG_LEVEL=info

# Aiven MySQL (recommended: URI)
DB_CONNECTION=mysql
DB_URL=mysql://avnadmin:your_password@mysql-xxxx.aivencloud.com:12345/defaultdb?ssl-mode=REQUIRED
MYSQL_ATTR_SSL_CA=/etc/ssl/certs/ca-certificates.crt

# If you use Aiven PostgreSQL instead:
# DB_CONNECTION=pgsql
# DB_URL=postgres://avnadmin:your_password@pg-xxxx.aivencloud.com:12345/defaultdb?sslmode=require
# DB_SSLMODE=require

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=sync

MAIL_MAILER=log
RUN_MIGRATIONS=true
SEED_ADMIN_ON_BOOT=true
ADMIN_EMAIL=admin@gmail.com
ADMIN_NAME=Admin
ADMIN_PASSWORD=change_me
