APP_NAME="Coupon Management System"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-service-name.onrender.com
APP_KEY=base64:replace_with_php_artisan_key_generate_show

LOG_CHANNEL=stderr
LOG_LEVEL=info

# MySQL
DB_CONNECTION=mysql
DB_HOST=db-host.example.com
DB_PORT=3306
DB_DATABASE=database_name
DB_USERNAME=db_user
DB_PASSWORD=your_password
# Optional: fallback to a direct IP when DNS resolution fails in your host environment.
# DB_HOST_IP=203.0.113.10

# If you use PostgreSQL instead:
# DB_CONNECTION=pgsql
# DB_HOST=db-host.example.com
# DB_PORT=5432
# DB_DATABASE=database_name
# DB_USERNAME=db_user
# DB_PASSWORD=your_password

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=sync

MAIL_MAILER=log
RUN_MIGRATIONS=true
SEED_ADMIN_ON_BOOT=true
SEED_COUPONS_ON_BOOT=true
ADMIN_EMAIL=admin@gmail.com
ADMIN_NAME=Admin
ADMIN_PASSWORD=change_me
